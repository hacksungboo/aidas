# aidas/deploy/onprem/ansible/roles/promtail_agent/templates/docker-compose-promtail.yml.j2
# 역할:
# - 각 노드에서 Promtail agent를 구동하는 Compose 템플릿
# - 호출 시점: promtail_agent role의 template task에서 렌더링
# - 수행 흐름:
#   - 호스트의 /var/log 경로를 읽어 로그를 수집
#   - positions 파일을 로컬에 저장하여 중복 수집 방지

version: "3.9"

services:
  promtail:
    image: {{ promtail_image }}
    container_name: promtail
    restart: unless-stopped
    command: -config.file=/etc/promtail/promtail-config.yaml
    volumes:
      - {{ promtail_config_dir }}/promtail-config.yaml:/etc/promtail/promtail-config.yaml:ro
      - /var/log/apps:/var/log/apps:ro
      - {{ promtail_positions_dir }}:{{ promtail_positions_dir }}