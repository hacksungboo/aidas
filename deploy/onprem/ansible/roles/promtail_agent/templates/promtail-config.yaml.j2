# aidas/deploy/onprem/ansible/roles/promtail_agent/templates/promtail-config.yaml.j2
# 역할:
# - Promtail 설정 템플릿
# - 호출 시점: promtail_agent role의 template task에서 렌더링
# - 수행 흐름:
#   - 각 노드의 /var/log/*.log를 Loki로 전송
#   - host label, job label을 부여해 Grafana Loki에서 필터링 가능하도록 설정

server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: {{ promtail_positions_file }}

clients:
  - url: {{ promtail_loki_url }}

scrape_configs:
  - job_name: {{ promtail_job_name }}
    static_configs:
      - targets:
          - localhost
        labels:
          job: {{ promtail_job_name }}
          host: {{ inventory_hostname }}
          __path__: {{ promtail_log_path }}

    pipeline_stages:
      # 1. 정규식(Regex)으로 로그 맨 앞의 레벨(ERROR/WARN 등)과 컴포넌트([DB/Connection] 등)를 추출합니다.
      # WARN 고유 표기 및 대소문자 방어를 위해 완벽히 매칭되도록 정규식을 구성했습니다.
      - regex:
          expression: '^(?P<level>WARNING|WARN|ERROR|FATAL|CRITICAL|INFO|DEBUG):\s*\[(?P<component>[^\]]+)\]\s*(?P<message>.*)'

      # 2. 파싱한 level과 component를 Loki 엔진이 인덱싱할 수 있도록 라벨(Label)로 등록합니다.
      - labels:
          level:
          component:

      # 3. [핵심] 수집 대상(WARNING, WARN, ERROR, FATAL, CRITICAL)이 아닌 정상 로그(INFO, DEBUG)는 통과시키지 않고 버립니다.
      - match:
          selector: '{level!~"WARNING|WARN|ERROR|FATAL|CRITICAL"}'
          action: drop